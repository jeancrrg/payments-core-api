# Active Spring profile (prod or test)
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL (used by both the app container and the postgres service)
DB_USERNAME=payments
DB_PASSWORD=payments
DB_URL=jdbc:postgresql://postgres:5432/payments

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Stripe (use a sk_test_ key from your Stripe dashboard)
STRIPE_API_KEY=sk_test_replace_me
